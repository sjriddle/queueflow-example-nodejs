# Where the QueueFlow server is listening.
QUEUEFLOW_URL=http://localhost:8000

# Bearer token. On the dev server any non-empty token authenticates.
QUEUEFLOW_TOKEN=dev

# Port for this Express service.
PORT=3000

# Queue this app's TypeScript worker leases from (src/worker.ts). Keep it
# different from the engine's default queue, which the server's own workers
# consume.
QUEUEFLOW_APP_QUEUE=app
